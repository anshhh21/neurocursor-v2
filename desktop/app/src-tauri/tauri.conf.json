{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NeuroCursor",
  "version": "0.1.0",
  "identifier": "com.neurocursor.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NeuroCursor V2",
        "width": 960,
        "height": 640,
        "minWidth": 820,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "externalBin": ["binaries/engine"]
  }
}
